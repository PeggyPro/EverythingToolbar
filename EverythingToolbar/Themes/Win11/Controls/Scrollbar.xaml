<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:Sys="clr-namespace:System;assembly=mscorlib">

    <Sys:Double x:Key="ScrollbarWidth">12</Sys:Double>
    <Sys:Double x:Key="ScrollbarThumbWidth">9</Sys:Double>
    <Sys:Double x:Key="ScrollbarThumbWidthHover">11</Sys:Double>
    <Sys:Double x:Key="ScrollbarThumbHeight">28</Sys:Double>
    <Thickness x:Key="ScrollbarThumbPadding"
               Left="3"
               Right="3" />
    <CornerRadius x:Key="ScrollbarThumbCornerRadius"
                  BottomLeft="2"
                  BottomRight="2"
                  TopLeft="2"
                  TopRight="2" />
    <CornerRadius x:Key="ScrollbarThumbCornerRadiusHover"
                  BottomLeft="3"
                  BottomRight="3"
                  TopLeft="3"
                  TopRight="3" />
    <CornerRadius x:Key="ScrollbarCornerRadius" />
    <Sys:String x:Key="ScrollbarArrowUpCornerRadius">0,0,0,0</Sys:String>
    <Sys:String x:Key="ScrollbarArrowUpContent">M 0 7 L 4 0 L 8 7 Z</Sys:String>
    <Sys:String x:Key="ScrollbarArrowDownCornerRadius">0,0,0,0</Sys:String>
    <Sys:String x:Key="ScrollbarArrowDownContent">M 0 1 L 4 8 L 8 1 Z</Sys:String>

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../../../Styles/Scrollbar.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
